{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["hardhat", "mocha", "chai"]
  },
  "include": ["./scripts", "./test", "./typechain-types", "./hardhat.config.ts"]
}
